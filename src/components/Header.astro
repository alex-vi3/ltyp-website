---
const pathname = Astro.url.pathname;

const links = [
  { href: '/actualites', label: 'ACTUALITÉS' },
  { href: '/entrainements', label: 'ENTRAÎNEMENTS' },
  { href: '/competitions', label: 'COMPÉTITIONS' },
  { href: '/nous-rejoindre', label: 'NOUS REJOINDRE' },
];

const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<div class="flex justify-between px-10 py-5 z-1 hidden xl:flex w-full">
  <a href="/">
    <img class="w-22 h-26" src="/logo.png" alt="Logo du club" />
  </a>

  <div class="flex gap-20">
    {
      links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'nav-link text-white text-lg hover-underline',
            isActive(href) && 'is-active',
          ]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))
    }

    <a
      href="/contact"
      class="relative inline-flex items-center justify-center py-1 px-5 overflow-hidden font-medium text-indigo-600 transition duration-300 ease-out rounded-md h-fit shadow-xl group hover:ring-1 hover:ring-red-900"
      aria-current={pathname === '/contact' ? 'page' : undefined}
    >
      <span
        class="absolute inset-0 w-full h-full bg-gradient-to-br from-red-500 via-red-700 to-red-900"
      ></span>
      <span class="relative text-white">CONTACT</span>
    </a>
  </div>
</div>

<style>
  .nav-link {
    position: relative;
    display: inline-block;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 2px;
    top: 30px;
    left: 0;
    background: linear-gradient(to right, var(--color-red-700));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease-out;
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  .nav-link.is-active {
    color: var(--color-red-200);
  }
</style>

---
import Button from '../Button.astro';
---

<div class="flex flex-col max-w-lg gap-6">
  <div class="flex gap-10 items-center">
    <h1 class="main-title flex-col">
      <span class="text-white text-5xl md:text-7xl xl:text-5xl 2xl:text-7xl"
        >LE TRAIT</span
      >
      <span class="text-white text-5xl md:text-7xl xl:text-5xl 2xl:text-7xl"
        >YAINVILLE</span
      >
      <span class="text-red-700 text-5xl md:text-7xl xl:text-5xl 2xl:text-7xl"
        >PONGISTE</span
      >
    </h1>
  </div>
  <p class="text-gray-200 font-medium">
    Au sein des communes du Trait et de Yainville, en Normandie, notre club
    familial permet à tous de pratiquer dans la bonne humeur tout en
    progressant, que ce soit en loisir ou en compétition
  </p>
  <Button text="Nous rejoindre" link="/nous-rejoindre" />
</div>

<style>
  .main-title {
    animation: slideInTitle 0.8s ease forwards;
  }

  .main-title span:nth-child(1) {
    animation-scroll-reveal-delay: 0s;
  }
  .main-title span:nth-child(2) {
    animation-scroll-reveal-delay: 0.15s;
  }
  .main-title span:nth-child(3) {
    animation-scroll-reveal-delay: 0.3s;
  }

  .main-title span {
    display: block;
    opacity: 0;
    animation: slideInTitle 0.6s ease forwards;
  }

  @keyframes slideInTitle {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .main-title span {
      animation: none;
      opacity: 1;
    }
  }
</style>

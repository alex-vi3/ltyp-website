---
import Button from '../Button.astro';
---

<div
  class="flex flex-col gap-10 items-center py-10 lg:py-30 px-10 background-pattern-points-red"
>
  <h2 class="text-white text-lg text-center lg:text-2xl" data-scroll-reveal>
    Vous souhaitez découvrir et progresser en tennis de table ?
  </h2>
  <Button
    text="Rejoignez-nous"
    link="/nous-rejoindre"
    data-scroll-reveal
    data-scroll-reveal-delay="200"
  />
</div>

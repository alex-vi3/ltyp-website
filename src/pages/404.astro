---
import backgroundImage from '../images/raquette3.webp';
import Button from '../components/Button.astro';
import LayoutPages from '../layouts/LayoutPages.astro';
---

<LayoutPages pageTitle="Erreur 404" srcImage={backgroundImage.src}>
  <section
    class="flex flex-col items-center text-center gap-6 px-10 py-16 lg:px-20 min-h-120"
  >
    <h2>Cette page n'existe pas.</h2>
    <p class="text-gray-800 max-w-2xl">
      La page que vous cherchez n'existe pas. Retournez à l'accueil pour
      retrouver toutes les dernières actualités du club.
    </p>
    <Button text="Retour à l'accueil" link="/" />
  </section>
</LayoutPages>
